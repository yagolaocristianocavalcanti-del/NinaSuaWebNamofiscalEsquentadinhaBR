<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCE4EC">

    <!-- 1. TELA DE PERMISSÕES (Só aparece na primeira vez) -->
    <LinearLayout
        android:id="@+id/permission_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="#FCE4EC"
        android:visibility="visible">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher_round" />

        <TextView
            android:id="@+id/nina_texto_inicial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ativa as permissões, amor! 😤"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="#AD1457"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btn_permissao_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Autorizar Sobreposição"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btn_permissao_uso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Autorizar Acesso ao Uso" />

        <Button
            android:id="@+id/btn_ativar_nina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TUDO PRONTO ❤️"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginTop="30dp" />
    </LinearLayout>

    <!-- 2. HOME DA NINA (Celular Rosinha com Apps Fake) -->
    <RelativeLayout
        android:id="@+id/nina_home_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8BBD0"
        android:visibility="gone">

        <!-- Wallpaper de fundo (pode ser um gradiente ou imagem) -->
        <TextView
            android:id="@+id/tv_home_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:34"
            android:textSize="60sp"
            android:textColor="#FFFFFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="60dp"
            android:textStyle="bold" />

        <!-- Grade de Apps Fake -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:layout_below="@id/tv_home_clock"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="72dp"
            android:padding="20dp">

            <!-- FOFOCAGRAMA (Instagram) -->
            <LinearLayout
                android:id="@+id/btn_abrir_insta"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="false"
                android:focusable="false">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_fofocagrama" android:background="#1a0533" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fofocagrama" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- VIGIMAIL (Gmail) -->
            <LinearLayout
                android:id="@+id/btn_abrir_gmail"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="false"
                android:focusable="false">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_vigimail" android:background="#0f2027" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vigimail" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- O CIÚMEZAP DA NINA -->
            <LinearLayout
                android:id="@+id/btn_abrir_zap"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_ciumezap"
                    android:background="#1a1a2e"
                    android:padding="12dp"
                    android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ciúmezap" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- CAPRICHOS DA NINA -->
            <LinearLayout
                android:id="@+id/btn_abrir_shein"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_caprichos"
                    android:background="#1a0a1a"
                    android:padding="12dp"
                    android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Caprichos" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- FOMEDELA (iFood) -->
            <LinearLayout
                android:id="@+id/btn_abrir_ifood"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_fomedela" android:background="#1a0d00" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fomedela" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- PERFUMARIA (Boticário) -->
            <LinearLayout
                android:id="@+id/btn_abrir_boticario"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_perfumaria" android:background="#001a0d" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Perfumaria" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- PETINHO (Petlove) -->
            <LinearLayout
                android:id="@+id/btn_abrir_petlove"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_petinho" android:background="#000d1a" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Petinho" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- DOCERIA DA NINA -->
            <LinearLayout
                android:id="@+id/btn_abrir_doceria"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:background="#1a0533"
                    android:padding="12dp"
                    android:elevation="4dp"
                    app:tint="#ce93d8" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Doceria" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- FLORES DA NINA -->
            <LinearLayout
                android:id="@+id/btn_abrir_flores"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:background="#1a0505"
                    android:padding="12dp"
                    android:elevation="4dp"
                    app:tint="#ef5350" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Flores" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- ENTREGA (Joguinhos no HTML) -->
            <LinearLayout
                android:id="@+id/btn_abrir_entrega_ifood"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_joguinhos"
                    android:background="#001a1a"
                    android:padding="12dp"
                    android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Entrega" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Em breve" android:textColor="#FFFDE7" android:textSize="9sp"/>
            </LinearLayout>

            <!-- AGENDINHA (Agenda) -->
            <LinearLayout
                android:id="@+id/btn_abrir_agenda"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_agendinha" android:background="#1a001a" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Agendinha" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- COFRE SECRETO (Banco) -->
            <LinearLayout
                android:id="@+id/btn_abrir_banco"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_cofre_secreto" android:background="#0d1a00" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cofre Secreto" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- CONFIGURAÇÕES (Ajustes) -->
            <LinearLayout
                android:id="@+id/btn_home_settings"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/ic_settings_nina" android:background="#0a0a0a" android:padding="12dp" android:elevation="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Configurações" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>
        </GridLayout>
    </RelativeLayout>

    <!-- 3. AGENDA DA NINA -->
    <RelativeLayout
        android:id="@+id/agenda_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8FB"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/header_agenda"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#5B3A8E"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="14dp">

            <ImageButton
                android:id="@+id/btn_fechar_agenda"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agenda"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_agenda_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semana da Nina"
                    android:textColor="#D8CFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/header_agenda"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/agenda_week_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tv_agenda_dom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_agenda_seg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_agenda_ter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_agenda_qua"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_agenda_qui"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_agenda_sex"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_agenda_sab"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#38112C"
                    android:textSize="14sp" />
            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

    <!-- 4. BANCO DA NINA -->
    <RelativeLayout
        android:id="@+id/bank_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7FA"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/header_bank"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#263238"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="14dp">

            <ImageButton
                android:id="@+id/btn_fechar_banco"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Banco"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_bank_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carteira da Nina"
                    android:textColor="#C5D0D6"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/header_bank"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tv_bank_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#4A1230"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_bank_balance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="16dp"
                    android:textColor="#102027"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_bank_salary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#102027"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_bank_bills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#102027"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_bank_statement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#102027"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_bank_index"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/balao_user"
                    android:padding="14dp"
                    android:textColor="#102027"
                    android:textSize="14sp" />
            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

    <!-- 5. CHAT DA NINA (Zap Estilo Original) -->
    <RelativeLayout
        android:id="@+id/chat_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E5DDD5"
        android:visibility="gone">

        <!-- Header Verde Zap -->
        <LinearLayout
            android:id="@+id/header_zap"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#075E54"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher_round" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nina ❤️"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="online"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/header_zap"
            android:layout_above="@+id/input_area_zap" />

        <!-- Barra de Input Zap Original -->
        <LinearLayout
            android:id="@+id/input_area_zap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:padding="5dp"
            android:background="#F0F0F0"
            android:elevation="8dp">

            <EditText
                android:id="@+id/et_mensagem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Mensagem"
                android:padding="12dp"
                android:background="@drawable/balao_user"
                android:textColor="#000000"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:layout_marginEnd="5dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_enviar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_send"
                app:fabSize="mini"
                app:backgroundTint="#075E54"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </RelativeLayout>

</FrameLayout>
