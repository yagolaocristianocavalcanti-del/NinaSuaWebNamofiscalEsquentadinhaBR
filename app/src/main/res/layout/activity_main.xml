<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCE4EC">

    <!-- 1. TELA DE PERMISSÕES (Só aparece na primeira vez) -->
    <LinearLayout
        android:id="@+id/permission_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="#FCE4EC"
        android:visibility="visible">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher_round" />

        <TextView
            android:id="@+id/nina_texto_inicial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ativa as permissões, amor! 😤"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="#AD1457"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btn_permissao_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Autorizar Sobreposição"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btn_permissao_uso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Autorizar Acesso ao Uso" />

        <Button
            android:id="@+id/btn_ativar_nina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TUDO PRONTO ❤️"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginTop="30dp" />
    </LinearLayout>

    <!-- 2. HOME DA NINA (Celular Rosinha com Apps Fake) -->
    <RelativeLayout
        android:id="@+id/nina_home_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8BBD0"
        android:visibility="gone">

        <!-- Wallpaper de fundo (pode ser um gradiente ou imagem) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:34"
            android:textSize="60sp"
            android:textColor="#FFFFFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="60dp"
            android:textStyle="bold" />

        <!-- Grade de Apps Fake -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:layout_centerInParent="true"
            android:padding="20dp">

            <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_margin="10dp">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/ic_menu_gallery" android:background="@drawable/balao_user" android:padding="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fotos" android:textColor="#FFFFFF" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_margin="10dp">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/ic_menu_camera" android:background="@drawable/balao_user" android:padding="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Câmera" android:textColor="#FFFFFF" android:textSize="10sp"/>
            </LinearLayout>

            <!-- O ZAP DA NINA (O Único que funciona) -->
            <LinearLayout
                android:id="@+id/btn_abrir_zap"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/sym_action_chat" android:background="#25D366" android:padding="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WhatsApp" android:textColor="#FFFFFF" android:textSize="10sp"/>
            </LinearLayout>

            <!-- MERCADO DA NINA -->
            <LinearLayout
                android:id="@+id/btn_abrir_mercado"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/ic_menu_view" android:background="#FFC107" android:padding="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mercado" android:textColor="#FFFFFF" android:textSize="10sp"/>
            </LinearLayout>

            <!-- AJUSTES DA NINA -->
            <LinearLayout
                android:id="@+id/btn_home_settings"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/ic_menu_manage" android:background="#607D8B" android:padding="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ajustes" android:textColor="#FFFFFF" android:textSize="10sp"/>
            </LinearLayout>
        </GridLayout>
    </RelativeLayout>

    <!-- 3. CHAT DA NINA (Zap Estilo Original) -->
    <RelativeLayout
        android:id="@+id/chat_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E5DDD5"
        android:visibility="gone">

        <!-- Header Verde Zap -->
        <LinearLayout
            android:id="@+id/header_zap"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#075E54"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher_round" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nina ❤️"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="online"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/header_zap"
            android:layout_above="@+id/input_area_zap" />

        <!-- Barra de Input Zap Original -->
        <LinearLayout
            android:id="@+id/input_area_zap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:padding="5dp"
            android:background="#00000000">

            <EditText
                android:id="@+id/et_mensagem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Mensagem"
                android:padding="12dp"
                android:background="@drawable/balao_user"
                android:textColor="#000000"
                android:layout_marginEnd="5dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_enviar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_send"
                app:fabSize="mini"
                app:backgroundTint="#075E54"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </RelativeLayout>

</FrameLayout>
