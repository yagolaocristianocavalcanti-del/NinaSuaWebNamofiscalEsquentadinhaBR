<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FCE4EC">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configurações da Nina ⚙️"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#AD1457"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Modelo da IA (.bin)"
        android:textStyle="bold"
        android:textColor="#4A1230" />
    <EditText
        android:id="@+id/et_model_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="/sdcard/Download/gemma3.bin"
        android:inputType="textUri"
        android:singleLine="true"
        android:textColor="#311B92"
        android:textColorHint="#880E4F"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_select_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESCOLHER ARQUIVO DO CÉREBRO"
        android:backgroundTint="#7E498F"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seu Nome (Como ela te chama)"
        android:textStyle="bold"
        android:textColor="#4A1230" />
    <EditText
        android:id="@+id/et_user_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="yago"
        android:textColor="#311B92"
        android:textColorHint="#880E4F"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:id="@+id/cb_ciumes_extremo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modo Ciúme Extremo (Beta)"
        android:textColor="#880E4F"
        android:buttonTint="#AD1457"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/cb_disponibilidade_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modo 100% Disponível (Testes)"
        android:textColor="#1B5E20"
        android:buttonTint="#2E7D32"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_save_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SALVAR TUDO"
        android:backgroundTint="#AD1457"
        android:textColor="#FFFFFF" />

</LinearLayout>
