<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Parking.Industrial" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/dark_gray</item>
        <item name="colorPrimaryVariant">@color/carbon_black</item>
        <item name="colorOnPrimary">@color/neon_green</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/neon_green</item>
        <item name="colorSecondaryVariant">@color/neon_green</item>
        <item name="colorOnSecondary">@color/carbon_black</item>

        <item name="android:windowBackground">@color/background_primary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background_primary</item>

        <item name="android:textColorPrimary">@color/neon_green</item>
        <item name="android:textColorSecondary">@color/white</item>
    </style>
</resources>
